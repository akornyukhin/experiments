{
  "version": "1.0",
  "name": "Simple product list",
  "template": "{\"type\":\"ListView\",\"children\":[{%- set _c -%}{%-for item in items -%},{\"type\":\"ListViewItem\",\"key\":{{ (item.name) | tojson }},\"gap\":3,\"children\":[{\"type\":\"Image\",\"src\":{{ (item.image) | tojson }},\"alt\":{{ (item.title) | tojson }},\"size\":56,\"aspectRatio\":1,\"radius\":\"sm\"},{\"type\":\"Col\",\"gap\":0,\"children\":[{\"type\":\"Row\",\"children\":[{\"type\":\"Text\",\"value\":{{ (item.title) | tojson }},\"size\":\"sm\",\"weight\":\"semibold\",\"maxLines\":1},{\"type\":\"Spacer\"},{\"type\":\"Badge\",\"label\":{{ (item.priceText) | tojson }},\"color\":\"info\",\"variant\":\"soft\"}]},{\"type\":\"Caption\",\"value\":{{ (item.description) | tojson }},\"color\":\"secondary\",\"maxLines\":1}]}]}{%-endfor-%}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]}",
  "jsonSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "priceText": {
              "type": "string"
            },
            "image": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "title",
            "description",
            "priceText",
            "image"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "items"
    ],
    "additionalProperties": false
  },
  "outputJsonPreview": {
    "type": "ListView",
    "children": [
      {
        "type": "ListViewItem",
